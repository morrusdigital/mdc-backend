// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkflowStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique @db.VarChar(255)
  name         String?        @db.VarChar(255)
  passwordHash String?        @map("password_hash") @db.VarChar(255)
  isActive     Boolean        @default(true) @map("is_active")
  lastLoginAt  DateTime?      @map("last_login_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  userRoles    UserRole[]
  sessions     AdminSession[]

  @@map("users")
}

model Role {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(100)
  name            String           @db.VarChar(255)
  description     String?          @db.Text
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(100)
  name            String           @db.VarChar(255)
  description     String?          @db.Text
  module          String           @db.VarChar(100)
  action          String           @db.VarChar(100)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AdminSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           Int       @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastUsedAt       DateTime? @map("last_used_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model Project {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique @db.VarChar(255)
  name           String   @db.VarChar(255)
  client         String   @db.VarChar(255)
  year           String   @db.VarChar(10)
  category       String   @db.VarChar(100)
  industry       String   @db.VarChar(100)
  serviceType    String   @map("service_type") @db.VarChar(255)
  summary        String   @db.Text
  challenge      String   @db.Text
  objective      String   @db.Text
  solution       String   @db.Text
  outcome        String   @db.Text
  deliverables   Json     // array of strings
  technologies   Json     // array of strings
  thumbnailLabel String   @map("thumbnail_label") @db.VarChar(10)
  thumbnailTone  String   @map("thumbnail_tone") @db.VarChar(20)
  gallery        Json     // array of { src: string, alt: string, caption: string }
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model Page {
  id             String        @id @default(uuid()) @db.Uuid
  title          String        @db.VarChar(255)
  slug           String        @unique @db.VarChar(255)
  excerpt        String?       @db.Text
  seoTitle       String?       @map("seo_title") @db.VarChar(255)
  seoDescription String?       @map("seo_description") @db.Text
  seoKeywords    Json?         @map("seo_keywords")
  isPublished    Boolean       @default(false) @map("is_published")
  publishedAt    DateTime?     @map("published_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  sections       PageSection[]
  navigationItems NavigationItem[]

  @@map("pages")
}

model PageSection {
  id        String   @id @default(uuid()) @db.Uuid
  pageId    String   @map("page_id") @db.Uuid
  type      String   @db.VarChar(100)
  label     String?  @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  isEnabled Boolean  @default(true) @map("is_enabled")
  content   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([pageId, sortOrder])
  @@map("page_sections")
}

model ServiceCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  services    Service[]

  @@map("service_categories")
}

model Service {
  id               String           @id @default(uuid()) @db.Uuid
  categoryId       String?          @map("category_id") @db.Uuid
  name             String           @db.VarChar(255)
  slug             String           @unique @db.VarChar(255)
  shortDescription String?          @map("short_description") @db.Text
  description      String?          @db.Text
  content          Json?
  iconName         String?          @map("icon_name") @db.VarChar(100)
  featured         Boolean          @default(false)
  sortOrder        Int              @default(0) @map("sort_order")
  isPublished      Boolean          @default(false) @map("is_published")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  category         ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([isPublished, sortOrder])
  @@map("services")
}

model NavigationMenu {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(100)
  name        String           @db.VarChar(255)
  description String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  items       NavigationItem[]

  @@map("navigation_menus")
}

model NavigationItem {
  id        String           @id @default(uuid()) @db.Uuid
  menuId    String           @map("menu_id") @db.Uuid
  parentId  String?          @map("parent_id") @db.Uuid
  pageId    String?          @map("page_id") @db.Uuid
  label     String           @db.VarChar(255)
  url       String           @db.VarChar(500)
  target    String?          @db.VarChar(50)
  sortOrder Int              @default(0) @map("sort_order")
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  menu      NavigationMenu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent    NavigationItem?  @relation("NavigationItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  NavigationItem[] @relation("NavigationItemChildren")
  page      Page?            @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([menuId])
  @@index([parentId])
  @@index([pageId])
  @@index([menuId, sortOrder])
  @@map("navigation_items")
}

model SiteSetting {
  id        String   @id @default(uuid()) @db.Uuid
  group     String   @db.VarChar(100)
  key       String   @db.VarChar(100)
  label     String?  @db.VarChar(255)
  value     Json
  valueType String   @map("value_type") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([group, key])
  @@index([group])
  @@map("site_settings")
}

model BlogCategory {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?    @db.Text
  sortOrder   Int        @default(0) @map("sort_order")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  blogPosts   BlogPost[]

  @@index([sortOrder])
  @@map("blog_categories")
}

model Tag {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @db.VarChar(255)
  slug         String        @unique @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  blogPostTags BlogPostTag[]

  @@map("tags")
}

model BlogPost {
  id                   String         @id @default(uuid()) @db.Uuid
  categoryId           String?        @map("category_id") @db.Uuid
  title                String         @db.VarChar(255)
  slug                 String         @unique @db.VarChar(255)
  excerpt              String?        @db.Text
  content              Json
  seoTitle             String?        @map("seo_title") @db.VarChar(255)
  seoDescription       String?        @map("seo_description") @db.Text
  seoKeywords          Json?          @map("seo_keywords")
  featured             Boolean        @default(false)
  status               WorkflowStatus @default(DRAFT)
  publishedAt          DateTime?      @map("published_at")
  approvedAt           DateTime?      @map("approved_at")
  submittedForReviewAt DateTime?      @map("submitted_for_review_at")
  archivedAt           DateTime?      @map("archived_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  category             BlogCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  blogPostTags         BlogPostTag[]

  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([featured, publishedAt])
  @@map("blog_posts")
}

model BlogPostTag {
  id         String   @id @default(uuid()) @db.Uuid
  blogPostId String   @map("blog_post_id") @db.Uuid
  tagId       String  @map("tag_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  blogPost    BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, tagId])
  @@index([blogPostId])
  @@index([tagId])
  @@map("blog_post_tags")
}

model CaseStudy {
  id                   String         @id @default(uuid()) @db.Uuid
  title                String         @db.VarChar(255)
  slug                 String         @unique @db.VarChar(255)
  clientName           String         @map("client_name") @db.VarChar(255)
  industry             String         @db.VarChar(100)
  serviceType          String         @map("service_type") @db.VarChar(255)
  summary              String         @db.Text
  challenge            String         @db.Text
  solution             String         @db.Text
  outcome              String         @db.Text
  results              Json?
  seoTitle             String?        @map("seo_title") @db.VarChar(255)
  seoDescription       String?        @map("seo_description") @db.Text
  seoKeywords          Json?          @map("seo_keywords")
  featured             Boolean        @default(false)
  status               WorkflowStatus @default(DRAFT)
  publishedAt          DateTime?      @map("published_at")
  approvedAt           DateTime?      @map("approved_at")
  submittedForReviewAt DateTime?      @map("submitted_for_review_at")
  archivedAt           DateTime?      @map("archived_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@index([featured, publishedAt])
  @@map("case_studies")
}

model Testimonial {
  id                   String         @id @default(uuid()) @db.Uuid
  name                 String         @db.VarChar(255)
  role                 String         @db.VarChar(255)
  company              String         @db.VarChar(255)
  quote                String         @db.Text
  rating               Int?
  sortOrder            Int            @default(0) @map("sort_order")
  featured             Boolean        @default(false)
  status               WorkflowStatus @default(DRAFT)
  publishedAt          DateTime?      @map("published_at")
  approvedAt           DateTime?      @map("approved_at")
  submittedForReviewAt DateTime?      @map("submitted_for_review_at")
  archivedAt           DateTime?      @map("archived_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@index([featured, sortOrder])
  @@map("testimonials")
}

model TeamMember {
  id                   String         @id @default(uuid()) @db.Uuid
  name                 String         @db.VarChar(255)
  slug                 String         @unique @db.VarChar(255)
  jobTitle             String         @map("job_title") @db.VarChar(255)
  bio                  String         @db.Text
  photoUrl             String?        @map("photo_url") @db.VarChar(500)
  linkedinUrl          String?        @map("linkedin_url") @db.VarChar(500)
  sortOrder            Int            @default(0) @map("sort_order")
  featured             Boolean        @default(false)
  status               WorkflowStatus @default(DRAFT)
  publishedAt          DateTime?      @map("published_at")
  approvedAt           DateTime?      @map("approved_at")
  submittedForReviewAt DateTime?      @map("submitted_for_review_at")
  archivedAt           DateTime?      @map("archived_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@index([featured, sortOrder])
  @@map("team_members")
}

model FaqCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  faqItems    FaqItem[]

  @@index([sortOrder])
  @@map("faq_categories")
}

model FaqItem {
  id                   String         @id @default(uuid()) @db.Uuid
  categoryId           String?        @map("category_id") @db.Uuid
  question             String         @db.Text
  answer               String         @db.Text
  sortOrder            Int            @default(0) @map("sort_order")
  featured             Boolean        @default(false)
  status               WorkflowStatus @default(DRAFT)
  publishedAt          DateTime?      @map("published_at")
  approvedAt           DateTime?      @map("approved_at")
  submittedForReviewAt DateTime?      @map("submitted_for_review_at")
  archivedAt           DateTime?      @map("archived_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  category             FaqCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([status, publishedAt])
  @@index([featured, sortOrder])
  @@map("faq_items")
}
