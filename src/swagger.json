{
  "openapi": "3.0.0",
  "info": {
    "title": "MDC Backend API Docs",
    "version": "2.0.0",
    "description": "Dokumentasi API statis untuk Morrus Digital Connecting CMS backend."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development Server"
    }
  ],
  "tags": [
    {
      "name": "General",
      "description": "Endpoint umum sistem"
    },
    {
      "name": "Public Portfolio",
      "description": "Endpoint publik untuk data portfolio"
    },
    {
      "name": "Admin Auth",
      "description": "Autentikasi admin CMS"
    },
    {
      "name": "Admin Users",
      "description": "Manajemen user admin CMS"
    },
    {
      "name": "Admin Roles",
      "description": "Manajemen role admin CMS"
    },
    {
      "name": "Admin Permissions",
      "description": "Daftar permission admin CMS"
    },
    {
      "name": "Admin Projects",
      "description": "Manajemen project di area admin CMS"
    },
    {
      "name": "Forms",
      "description": "Fondasi endpoint public forms"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Masukkan JWT access token admin."
      }
    },
    "schemas": {
      "SuccessEnvelope": {
        "type": "object",
        "required": ["success", "message"],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Request berhasil diproses"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["success", "message"],
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Unauthorized"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "example": "email"
                },
                "message": {
                  "type": "string",
                  "example": "Invalid email address"
                }
              }
            }
          }
        }
      },
      "HomeResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "example": "MDC Backend API is running"
              }
            }
          }
        ]
      },
      "DbTestResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "message": {
                "type": "string",
                "example": "PostgreSQL connected"
              },
              "data": {
                "type": "object",
                "properties": {
                  "now": {
                    "type": "string",
                    "example": "2026-07-02T01:51:47.000Z"
                  }
                }
              }
            }
          }
        ]
      },
      "GalleryItem": {
        "type": "object",
        "required": ["src", "alt", "caption"],
        "properties": {
          "src": {
            "type": "string",
            "example": "/uploads/image.png"
          },
          "alt": {
            "type": "string",
            "example": "Screenshot aplikasi"
          },
          "caption": {
            "type": "string",
            "example": "Halaman utama"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "a4d3f58a-f2b1-419b-a01f-0e12f6723223"
          },
          "slug": {
            "type": "string",
            "example": "jaladewa-champion"
          },
          "name": {
            "type": "string",
            "example": "Jaladewa Champion"
          },
          "client": {
            "type": "string",
            "example": "Pemerintah Kota"
          },
          "year": {
            "type": "string",
            "example": "2026"
          },
          "category": {
            "type": "string",
            "example": "Company Profile"
          },
          "industry": {
            "type": "string",
            "example": "Pendidikan & Olahraga"
          },
          "serviceType": {
            "type": "string",
            "example": "Attendance & Operational Management System"
          },
          "summary": {
            "type": "string",
            "example": "Ringkasan proyek."
          },
          "challenge": {
            "type": "string",
            "example": "Tantangan pengerjaan."
          },
          "objective": {
            "type": "string",
            "example": "Tujuan proyek."
          },
          "solution": {
            "type": "string",
            "example": "Solusi sistem."
          },
          "outcome": {
            "type": "string",
            "example": "Hasil nyata."
          },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["Jadwal latihan", "Invoice"]
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["React", "TypeScript", "Node.js"]
          },
          "thumbnailLabel": {
            "type": "string",
            "example": "JC"
          },
          "thumbnailTone": {
            "type": "string",
            "example": "sky"
          },
          "gallery": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GalleryItem"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProjectCreateInput": {
        "type": "object",
        "required": [
          "slug",
          "name",
          "client",
          "year",
          "category",
          "industry",
          "serviceType",
          "summary",
          "challenge",
          "objective",
          "solution",
          "outcome",
          "deliverables",
          "technologies",
          "thumbnailLabel",
          "thumbnailTone",
          "gallery"
        ],
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "client": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "serviceType": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "solution": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "thumbnailLabel": {
            "type": "string"
          },
          "thumbnailTone": {
            "type": "string"
          },
          "gallery": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GalleryItem"
            }
          }
        }
      },
      "ProjectPatchInput": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "client": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "serviceType": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "challenge": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "solution": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "thumbnailLabel": {
            "type": "string"
          },
          "thumbnailTone": {
            "type": "string"
          },
          "gallery": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GalleryItem"
            }
          }
        }
      },
      "Permission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "code": {
            "type": "string",
            "example": "users.read"
          },
          "name": {
            "type": "string",
            "example": "Users Read"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Read admin users"
          },
          "module": {
            "type": "string",
            "example": "users"
          },
          "action": {
            "type": "string",
            "example": "read"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RoleSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "code": {
            "type": "string",
            "example": "super_admin"
          },
          "name": {
            "type": "string",
            "example": "Super Admin"
          }
        }
      },
      "Role": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "code": {
            "type": "string",
            "example": "super_admin"
          },
          "name": {
            "type": "string",
            "example": "Super Admin"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "isSystem": {
            "type": "boolean",
            "example": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Permission"
            }
          }
        }
      },
      "UserSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "email": {
            "type": "string",
            "example": "admin@mdc.local"
          },
          "name": {
            "type": "string",
            "nullable": true,
            "example": "Bootstrap Admin"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "lastLoginAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RoleSummary"
            }
          }
        }
      },
      "AuthUserProfile": {
        "allOf": [
          {
            "$ref": "#/components/schemas/UserSummary"
          },
          {
            "type": "object",
            "properties": {
              "permissions": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": ["users.read", "roles.read", "projects.create"]
              }
            }
          }
        ]
      },
      "TokenBundle": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "sessionId": {
            "type": "string",
            "format": "uuid",
            "example": "bb345495-7dc8-42f0-8db7-2ac39dc6206f"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserProfile"
          }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@mdc.local"
          },
          "password": {
            "type": "string",
            "format": "password",
            "example": "ChangeMe123!"
          }
        }
      },
      "RefreshTokenInput": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "CreateUserInput": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "format": "password"
          },
          "isActive": {
            "type": "boolean",
            "default": true
          },
          "roleIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [1]
          }
        }
      },
      "UpdateUserInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "UpdateUserStatusInput": {
        "type": "object",
        "required": ["isActive"],
        "properties": {
          "isActive": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "AssignUserRolesInput": {
        "type": "object",
        "required": ["roleIds"],
        "properties": {
          "roleIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [1, 2]
          }
        }
      },
      "CreateRoleInput": {
        "type": "object",
        "required": ["code", "name"],
        "properties": {
          "code": {
            "type": "string",
            "example": "editor"
          },
          "name": {
            "type": "string",
            "example": "Editor"
          },
          "description": {
            "type": "string",
            "example": "Role custom untuk editor konten"
          },
          "permissionIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [5, 6, 17, 18]
          }
        }
      },
      "UpdateRoleInput": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "AssignRolePermissionsInput": {
        "type": "object",
        "required": ["permissionIds"],
        "properties": {
          "permissionIds": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [1, 2, 3]
          }
        }
      },
      "ProjectListResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          }
        ]
      },
      "ProjectResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/Project"
              }
            }
          }
        ]
      },
      "UserListResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/UserSummary"
                }
              }
            }
          }
        ]
      },
      "UserResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/AuthUserProfile"
              }
            }
          }
        ]
      },
      "RoleListResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Role"
                }
              }
            }
          }
        ]
      },
      "RoleResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/Role"
              }
            }
          }
        ]
      },
      "PermissionListResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Permission"
                }
              }
            }
          }
        ]
      },
      "TokenResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "required": ["data"],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/TokenBundle"
              }
            }
          }
        ]
      },
      "FormsFoundationResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "example": "Forms API foundation is ready"
              }
            }
          }
        ]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Validasi input gagal / parameter tidak valid",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Token hilang, tidak valid, atau sudah expired",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "User terautentikasi tetapi tidak memiliki permission",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource tidak ditemukan",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "Terjadi konflik data",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Terjadi kesalahan server internal",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "tags": ["General"],
        "summary": "Welcome Home",
        "description": "Mengembalikan status running dari API.",
        "responses": {
          "200": {
            "description": "API aktif",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HomeResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/db-test": {
      "get": {
        "tags": ["General"],
        "summary": "Database Connection Test",
        "description": "Menguji koneksi PostgreSQL.",
        "responses": {
          "200": {
            "description": "Koneksi database berhasil",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DbTestResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/public/portfolio": {
      "get": {
        "tags": ["Public Portfolio"],
        "summary": "List public portfolio",
        "responses": {
          "200": {
            "description": "Daftar portfolio berhasil diambil",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/public/portfolio/{slug}": {
      "get": {
        "tags": ["Public Portfolio"],
        "summary": "Get public portfolio detail",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detail portfolio ditemukan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/forms": {
      "get": {
        "tags": ["Forms"],
        "summary": "Forms foundation health",
        "responses": {
          "200": {
            "description": "Forms API foundation tersedia",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormsFoundationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/auth/login": {
      "post": {
        "tags": ["Admin Auth"],
        "summary": "Login admin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInput"
              }
